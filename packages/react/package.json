{
  "name": "@figtree/react",
  "version": "1.0.0",
  "description": "React provider for Figtree design tokens",
  "license": "MIT",
  "keywords": ["figtree", "design-tokens", "figma", "react", "tokens"],
  "homepage": "https://github.com/nhunsaker/figtree#readme",
  "bugs": "https://github.com/nhunsaker/figtree/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhunsaker/figtree.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "prepublishOnly": "node build.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "react": "^18.0.0"
  }
}
